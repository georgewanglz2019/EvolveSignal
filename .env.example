# Copy to .env in the project root and fill in values.
# OpenRouter (or any OpenAI-compatible API you set in config.yaml)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: if SUMO is not auto-detected, set the install root (folder containing tools/)
# Windows example:
# SUMO_HOME=C:\Program Files (x86)\Eclipse\Sumo
# Linux example:
# SUMO_HOME=/usr/share/sumo
